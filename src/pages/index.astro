---
const title = "Notitas para mi estimada";
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const imagePath = `${baseUrl}images/isa.jpeg`;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <main class="page">
      <section class="card">
        <p class="small-text">Especialmente para vuestra merced</p>

        <h1>Notitas para mi estimada</h1>

        <div class="photo-container">
          <img src="/notas-belita/images/isa.jpeg" alt="Foto de nosotros" />
        </div>

        <div class="message-box">
          <p id="loveMessage">
            Presiona el botón para recibir una notita.
          </p>
        </div>

        <button id="changeMessageBtn">
          Notita nueva
        </button>
      </section>
    </main>

    <script>
      const messages = [
        "Eres mi lugar favorito en el mundo.",
        "Cada día contigo se siente más bonito.",
        "Tu sonrisa tiene el poder de mejorar cualquier día.",
        "Gracias por existir y por hacer mi vida más feliz.",
        "Me encantas más de lo que las palabras pueden explicar.",
        "Si pudiera elegir otra vez, te volvería a elegir a ti.",
        "Contigo todo se siente más tranquilo, más bonito y más real.",
        "Eres mi pensamiento favorito del día.",
        "No necesito un día especial para recordarte cuánto te amo.",
        "Tú haces que las cosas simples se vuelvan mágicas."
      ];

      const messageElement = document.getElementById("loveMessage");
      const button = document.getElementById("changeMessageBtn");

      button?.addEventListener("click", () => {
        const randomIndex = Math.floor(Math.random() * messages.length);
        if (messageElement) {
          messageElement.textContent = messages[randomIndex];
        }
      });
    </script>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: Arial, Helvetica, sans-serif;
    background: linear-gradient(135deg, #ffd1dc, #ffb6c1, #ffc0cb);
    min-height: 100vh;
  }

  .page {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 24px;
  }

  .card {
    width: 100%;
    max-width: 420px;
    background: rgba(255, 255, 255, 0.82);
    border-radius: 28px;
    padding: 32px 24px;
    text-align: center;
    box-shadow: 0 18px 40px rgba(180, 80, 120, 0.28);
    border: 2px solid rgba(255, 255, 255, 0.65);
  }

  .small-text {
    color: #b84f7a;
    font-size: 14px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  h1 {
    color: #8f2d56;
    font-size: 32px;
    margin-bottom: 24px;
  }

  .photo-container {
    width: 220px;
    height: 220px;
    margin: 0 auto 24px;
    border-radius: 50%;
    padding: 8px;
    background: #ffffff;
    box-shadow: 0 12px 28px rgba(143, 45, 86, 0.25);
  }

  .photo-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  .message-box {
    min-height: 120px;
    background: #fff5f8;
    border-radius: 20px;
    padding: 22px;
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid #ffd6e4;
  }

  .message-box p {
    color: #7a2848;
    font-size: 18px;
    line-height: 1.5;
    font-weight: 500;
  }

  button {
    background: #e75480;
    color: white;
    border: none;
    border-radius: 999px;
    padding: 14px 28px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 10px 22px rgba(231, 84, 128, 0.35);
  }

  button:hover {
    background: #d84373;
    transform: translateY(-2px);
    box-shadow: 0 14px 26px rgba(231, 84, 128, 0.45);
  }

  button:active {
    transform: scale(0.97);
  }

  @media (max-width: 480px) {
    .card {
      padding: 28px 18px;
    }

    h1 {
      font-size: 28px;
    }

    .photo-container {
      width: 190px;
      height: 190px;
    }

    .message-box p {
      font-size: 17px;
    }
  }
</style>